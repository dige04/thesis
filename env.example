# Copy this file to .env and fill in real values. Never commit .env.

# ───────────────────────────────────────────────────────────
# Model APIs
# ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Main agent model (locked: GPT-5.4)
MAIN_MODEL=gpt-5.4

# Helper models (reflection, summarization, type classification)
SUMMARY_MODEL=gpt-4o-mini
CLASSIFIER_MODEL=gpt-4o-mini

# Embedding model for FAISS retrieval
EMBEDDING_MODEL=text-embedding-3-small

# Multi-model validation (Week 7 — top-3 conditions × 4 sequences × 1 seed)
VALIDATION_MODEL=claude-haiku-4-5-20251001
# or: gpt-4o-mini

# ───────────────────────────────────────────────────────────
# Experiment tracking
# ───────────────────────────────────────────────────────────
WANDB_API_KEY=...
WANDB_PROJECT=memory-pruning-thesis
WANDB_ENTITY=...

# ───────────────────────────────────────────────────────────
# SWE-Bench harness
# ───────────────────────────────────────────────────────────
# Docker concurrency — start at 4, ramp gradually while monitoring iostat
SWEBENCH_MAX_WORKERS=4
SWEBENCH_CACHE_DIR=./.swebench_cache

# ───────────────────────────────────────────────────────────
# Budget guards (hard caps — runner aborts if exceeded)
# ───────────────────────────────────────────────────────────
DAILY_COST_LIMIT_USD=200
PER_TASK_COST_LIMIT_USD=5.00
MAX_STEPS_PER_TASK=20            # LOCKED — see CLAUDE.md
MAX_WALL_TIME_MINUTES=20         # LOCKED — see CLAUDE.md

# ───────────────────────────────────────────────────────────
# Reproducibility
# ───────────────────────────────────────────────────────────
MASTER_SEED=42
