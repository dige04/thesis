# ─────────────────────────────────────────────────────────────────
# Project-specific — experiment artifacts (LARGE)
# ─────────────────────────────────────────────────────────────────
# Per-run logs and memory state. 144 runs × per-task logs adds up fast.
runs/

# Raw aggregated results. Plots and final tables in results/ committed manually.
results/raw/
results/cache/

# Vector indices and metadata stores
*.faiss
*.index
*.sqlite
*.sqlite-journal
*.db

# wandb local cache
wandb/
.wandb/

# Docker artifacts left behind by eval_v3
.swebench_cache/
swebench_logs/

# Data files (curriculum JSON is large and should be downloaded separately)
data/*.json
data/*.jsonl

# ─────────────────────────────────────────────────────────────────
# Secrets / credentials
# ─────────────────────────────────────────────────────────────────
*.key
*.pem
secrets.yaml
secrets.yml
secrets.json
.netrc

# ─────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─────────────────────────────────────────────────────────────────
# OS / misc
# ─────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────────
# DO commit (explicit allow)
# ─────────────────────────────────────────────────────────────────
!results/plots/
!results/tables/
!results/aggregated/*.json
!results/aggregated/*.csv

# Keep otherwise-empty (gitignored) dirs tracked via .gitkeep placeholders.
# A bare `!dir/.gitkeep` is not enough when `dir/` is excluded by a dir
# pattern, so re-include the directory first, then re-exclude its contents.
!runs/
runs/*
!runs/.gitkeep
!logs/
logs/*
!logs/.gitkeep
!results/raw/
results/raw/*
!results/raw/.gitkeep

# Local agent/tooling state (oh-my-claudecode, antigravity) — not thesis code
.omc/
.antigravitycli/
