[Unit]
Description=Thesis fleet doctor (shard %i) - disk/ollama/matrix heal + heartbeat
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/thesis
Environment=RUNS_ROOT=runs
ExecStart=/bin/bash /root/thesis/scripts/doctor.sh %i
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
