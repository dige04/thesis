# .env.example — copy to .env (gitignored) and fill in.
# Loaded automatically by src/config/llm_factory.py via python-dotenv.
#
# Precedence: these env vars override the built-in defaults in llm_factory.py.
# Leave a line unset to accept the default shown in the comment.
#
# ─────────────────────────────────────────────────────────────────────────────
# CHAT / AGENT / SUMMARY / CLASSIFIER  — OpenCode Zen "go" (OpenAI-compatible)
# Catalog: curl -H "Authorization: Bearer $KEY" https://opencode.ai/zen/go/v1/models
# NOTE: Qwen models on this tier are Anthropic-endpoint only (not oa-compat).
#       Use the kimi / glm / deepseek / minimax / mimo families for OpenAI-compat.
# ─────────────────────────────────────────────────────────────────────────────
LLM_CHAT_BASE_URL=https://opencode.ai/zen/go/v1
LLM_CHAT_API_KEY=                        # REQUIRED. Create at https://opencode.ai (Zen console)
LLM_MAIN_MODEL=kimi-k2.6                 # main coding agent (oa-compat, large ctx)
LLM_SUMMARY_MODEL=kimi-k2.5              # reflection + CLS consolidation summaries
LLM_CLASSIFIER_MODEL=kimi-k2.5           # 5-type memory classifier (JSON-mode verified)

# ─────────────────────────────────────────────────────────────────────────────
# EMBEDDINGS — local Ollama daemon (Ollama Cloud serves NO embedding model)
# Run `ollama serve`, then `ollama pull nomic-embed-text-v2-moe`.
# Do NOT set a global OPENAI_BASE_URL — it would redirect this client too.
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama                 # local daemon requires a non-empty token but ignores its value
EMBEDDING_MODEL=nomic-embed-text-v2-moe  # alt: qwen3-embedding (0.6b=1024-dim, 4b/8b larger)
EMBEDDING_DIM=768                         # MUST match the embedder; rebuild FAISS index if changed

# ── Alternative embedding choice: qwen3-embedding:0.6b (1024-dim) ──
# EMBEDDING_MODEL=qwen3-embedding:0.6b
# EMBEDDING_DIM=1024

# ── Alternative: keep embeddings on OpenAI text-embedding-3-small (1536-dim) ──
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-openai-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ─────────────────────────────────────────────────────────────────────────────
# COST METRIC — Ollama is flat-rate (GPU-time), so per-token USD is meaningless.
# Pareto x-axis falls back to this proxy. One of: usd | tokens | walltime
# ─────────────────────────────────────────────────────────────────────────────
COST_METRIC_MODE=tokens
